<%- include('partials/header') %>
<h1>Admin</h1>

<section>
  <h2>Users</h2>
  <table>
    <thead>
      <tr><th>ID</th><th>Username</th><th>Role</th></tr>
    </thead>
    <tbody>
      <% users.forEach(function(u){ %>
        <tr>
          <td><%= u.id %></td>
          <td><%= u.username %></td>
          <td><%= u.role %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>

<section>
  <h2>All posts</h2>
  <table>
    <thead>
      <tr><th>ID</th><th>Title</th><th>Author</th><th>Created</th></tr>
    </thead>
    <tbody>
      <% posts.forEach(function(p){ %>
        <tr>
          <td><%= p.id %></td>
          <td><a href="/posts/<%= p.id %>"><%= p.title %></a></td>
          <td><%= p.author %></td>
          <td><%= p.created_at %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>
<%- include('partials/footer') %>
