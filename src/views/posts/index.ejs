<%- include('../partials/header') %>
<h1>Posts</h1>
<p><a href="/posts/new">+ New post</a></p>
<% if (posts.length === 0) { %>
  <p>No posts yet.</p>
<% } else { %>
  <ul class="post-list">
    <% posts.forEach(function(p){ %>
      <li>
        <a href="/posts/<%= p.id %>"><%= p.title %></a>
        <small>by <%= p.author %> &mdash; <%= p.created_at %></small>
      </li>
    <% }) %>
  </ul>
<% } %>
<%- include('../partials/footer') %>
